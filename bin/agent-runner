#!/usr/bin/env bun
// Bootstrap: run from source when src is newer than the compiled bundle,
// otherwise prefer dist for faster cold-start. Without the freshness check
// a stale dist/cli/index.js shadows the fixes you just edited — that's a
// real footgun (see commit history for ~half a day of bug-hunting that
// turned out to be exactly this).
import { fileURLToPath } from "node:url";
import { dirname, resolve } from "node:path";
import { existsSync, statSync, readdirSync } from "node:fs";

const here = dirname(fileURLToPath(import.meta.url));
const distPath = resolve(here, "../dist/cli/index.js");
const srcDir = resolve(here, "../src");
const srcPath = resolve(srcDir, "cli/index.ts");

function newestMtime(path: string): number {
  try {
    const st = statSync(path);
    if (!st.isDirectory()) return st.mtimeMs;
    let best = st.mtimeMs;
    for (const ent of readdirSync(path, { withFileTypes: true })) {
      const child = resolve(path, ent.name);
      const m = newestMtime(child);
      if (m > best) best = m;
    }
    return best;
  } catch {
    return 0;
  }
}

let entry = srcPath;
if (existsSync(distPath)) {
  const distMtime = statSync(distPath).mtimeMs;
  const srcMtime = newestMtime(srcDir);
  entry = srcMtime > distMtime ? srcPath : distPath;
}
await import(entry);
